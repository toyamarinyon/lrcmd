#!/bin/sh

set -eu

ENKA_VERSION=${ENKA_VERSION:-}
ENKA_INSTALL_ORIGIN=${ENKA_INSTALL_ORIGIN:-https://enka.ultrahope.dev}
ENKA_RELEASE_BASE_URL=${ENKA_RELEASE_BASE_URL:-https://github.com/toyamarinyon/enka/releases/download}
ENKA_INSTALL_ROOT=${ENKA_INSTALL_ROOT:-"$HOME/Applications/enka"}
ENKA_SKIP_SETUP=${ENKA_SKIP_SETUP:-0}
ENKA_SETUP_WAIT_ACCESSIBILITY_SECONDS=${ENKA_SETUP_WAIT_ACCESSIBILITY_SECONDS:-}

step() {
  if [ -t 1 ]; then
    printf '→ %s' "$1"
  else
    printf '→ %s\n' "$1"
  fi
}

done_step() {
  if [ -t 1 ]; then
    printf '\r\033[K✓ %s\n' "$1"
  else
    printf '✓ %s\n' "$1"
  fi
}

if [ -z "$ENKA_VERSION" ]; then
  LATEST_JSON=$(curl -fsSL "${ENKA_INSTALL_ORIGIN%/}/latest.json")
  ENKA_VERSION=$(printf '%s' "$LATEST_JSON" | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)
  if [ -z "$ENKA_VERSION" ]; then
    echo "error: could not resolve latest enka version" >&2
    exit 1
  fi
fi

OS=$(uname -s)
if [ "$OS" != "Darwin" ]; then
  echo "error: hosted installer currently supports macOS only" >&2
  exit 1
fi

ARCH=$(uname -m)
case "$ARCH" in
  arm64)
    ENKA_PLATFORM="macos-arm64"
    ;;
  x86_64)
    ENKA_PLATFORM="macos-x86_64"
    ;;
  *)
    echo "error: unsupported architecture: $ARCH" >&2
    exit 1
    ;;
esac

ARCHIVE_NAME="enka-v${ENKA_VERSION}-${ENKA_PLATFORM}.tar.gz"
if [ -n "${ENKA_BASE_URL:-}" ]; then
  ARCHIVE_URL="${ENKA_BASE_URL%/}/${ARCHIVE_NAME}"
else
  ARCHIVE_URL="${ENKA_RELEASE_BASE_URL%/}/v${ENKA_VERSION}/${ARCHIVE_NAME}"
fi
CHECKSUM_URL="${ARCHIVE_URL}.sha256"

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

ARCHIVE_PATH="$TMP_DIR/$ARCHIVE_NAME"
CHECKSUM_PATH="$TMP_DIR/$ARCHIVE_NAME.sha256"

echo "Installing enka $ENKA_VERSION ($ENKA_PLATFORM)"
step "Downloading $ARCHIVE_NAME"
curl -fsSL "$ARCHIVE_URL" -o "$ARCHIVE_PATH"
done_step "Downloaded $ARCHIVE_NAME"

if curl -fsSL "$CHECKSUM_URL" -o "$CHECKSUM_PATH"; then
  step "Verifying checksum"
  (cd "$TMP_DIR" && shasum -a 256 -c "$ARCHIVE_NAME.sha256" >/dev/null)
  done_step "Checksum verified"
else
  echo "Checksum: unavailable" >&2
fi

EXTRACT_DIR="$TMP_DIR/extract"
mkdir -p "$EXTRACT_DIR"
step "Extracting archive"
tar -xzf "$ARCHIVE_PATH" -C "$EXTRACT_DIR"
done_step "Extracted archive"

if [ ! -x "$EXTRACT_DIR/bin/enka" ]; then
  echo "error: extracted archive does not contain expected binary" >&2
  exit 1
fi
if [ ! -x "$EXTRACT_DIR/Enka.app/Contents/MacOS/Enka" ] || [ ! -f "$EXTRACT_DIR/Enka.app/Contents/Info.plist" ]; then
  echo "error: extracted archive does not contain expected app bundle" >&2
  exit 1
fi

step "Installing files"
mkdir -p "$ENKA_INSTALL_ROOT/bin"
cp "$EXTRACT_DIR/bin/enka" "$ENKA_INSTALL_ROOT/bin/enka"
mkdir -p "$ENKA_INSTALL_ROOT"
rm -rf "$ENKA_INSTALL_ROOT/Enka.app"
cp -R "$EXTRACT_DIR/Enka.app" "$ENKA_INSTALL_ROOT/"

if [ ! -x "$ENKA_INSTALL_ROOT/bin/enka" ] || [ ! -x "$ENKA_INSTALL_ROOT/Enka.app/Contents/MacOS/Enka" ] || [ ! -f "$ENKA_INSTALL_ROOT/Enka.app/Contents/Info.plist" ]; then
  echo "error: installed files are missing or not runnable" >&2
  exit 1
fi
done_step "Installed $ENKA_INSTALL_ROOT"

if [ "$ENKA_SKIP_SETUP" = "1" ]; then
  echo "✓ Setup skipped"
  echo "Next: $ENKA_INSTALL_ROOT/bin/enka install"
  exit 0
fi

if [ -n "$ENKA_SETUP_WAIT_ACCESSIBILITY_SECONDS" ]; then
  if ! "$ENKA_INSTALL_ROOT/bin/enka" install --wait-accessibility "$ENKA_SETUP_WAIT_ACCESSIBILITY_SECONDS"; then
    echo "error: install failed. run \"$ENKA_INSTALL_ROOT/bin/enka install --wait-accessibility $ENKA_SETUP_WAIT_ACCESSIBILITY_SECONDS\" to retry" >&2
    exit 1
  fi
else
  if ! "$ENKA_INSTALL_ROOT/bin/enka" install; then
    echo "error: install failed. run \"$ENKA_INSTALL_ROOT/bin/enka install\" to retry" >&2
    exit 1
  fi
fi

echo ""
echo "✓ Setup complete! Use left/right Command to switch input sources."
echo "  Document: https://github.com/toyamarinyon/enka"
